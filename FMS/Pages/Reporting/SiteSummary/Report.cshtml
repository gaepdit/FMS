@page
@using FMS.Domain.Dto
@using FMS.Domain.Entities.Users
@using FMS.Platform.Extensions
@model FMS.Pages.Reporting.SiteSummary.ReportModel
@{
    Layout = "_ReportLayout";
}

@{
    ViewData["Title"] = $"Site Summary(s)";
}

@if (Model.ReportList.Count == 0)
{
    <p class="lead text-info">No matching results found.</p>
}
else
{
    @foreach (var report in Model.ReportList)
    {
        <div class="page-wrapper">
            <div class="mb-5">
                <h2>@report.Name (@report.FacilityNumber)</h2>
                <p><strong>Organizational Unit:</strong> @report.OrganizationalUnit.Name</p>
                <p><strong>Compliance Officer:</strong> @report.ComplianceOfficer.Name</p>
                <hr />
                <h3>Address:</h3>
                <p><strong>Street:</strong> @report.Address</p>
                <p><strong>City:</strong> @report.City</p>
                <p><strong>County:</strong> @report.County.Name</p>
                <p><strong>State:</strong> @report.State</p>
                <p><strong>Zip Code:</strong> @report.PostalCode</p>
                <hr />
                <h3>Contact Information:</h3>
                @foreach (var contact in report.Contacts)
                {
                    @if (contact.ContactType.Name == "Property Owner")
                    {
                        <p><strong>Name:</strong> @contact.GivenName @contact.FamilyName</p>
                        <p><strong>Title:</strong> @contact.ContactTitle</p>
                        <p><strong>Type:</strong> @contact.ContactType.Name</p>
                        <p><strong>Address:</strong> @contact.Address</p>
                        <p><strong>City:</strong> @contact.City</p>
                        <p><strong>Zip Code:</strong> @contact.PostalCode</p>
                        <p><strong>State:</strong> @contact.State</p>
                        <p><strong>Email:</strong> @contact.Email</p>
                        <hr />
                    }
                }
                <h3>Parcels</h3>
                @foreach (var parcel in report.Parcels)
                {
                    <p><strong>Parcel Number:</strong> @parcel.ParcelNumber</p>
                    <p><strong>Sublist Parcel Name:</strong> @parcel.SubListParcelName</p>
                    <p><strong>Size (acres):</strong> @parcel.Acres</p>
                    <p><strong>Listed Date:</strong> @parcel.ListDate</p>
                    <hr />
                }
                <h3>Class</h3>
                <p><strong>Class:</strong> @report.LocationDetails.LocationClass.DisplayName</p>
                <hr />
                <h3>Score Details</h3>
                <p><strong>Score Comments:</strong> @report.ScoreDetails.Comments</p>
                <p><strong>Score Date:</strong> @report.ScoreDetails.ScoredDate</p>
                <h3>Onsite Score Details</h3>
                <p><strong>A:</strong> @report.OnsiteScoreDetails.A</p>
                <p><strong>B:</strong> @report.OnsiteScoreDetails.B</p>
                <p><strong>C:</strong> @report.OnsiteScoreDetails.C</p>
                <p><strong>CASNO:</strong> @report.OnsiteScoreDetails.CASNO</p>
                <p><strong>ChemName1D:</strong> @report.OnsiteScoreDetails.ChemName1D</p>
                <p><strong>Other1D:</strong> @report.OnsiteScoreDetails.Other1D</p>
                <p><strong>D2:</strong> @report.OnsiteScoreDetails.D2</p>
                <p><strong>D3:</strong> @report.OnsiteScoreDetails.D3</p>
                <p><strong>E1:</strong> @report.OnsiteScoreDetails.E1</p>
                <p><strong>E2:</strong> @report.OnsiteScoreDetails.E2</p>
                <p><strong>Description:</strong> @report.OnsiteScoreDetails.Description</p>
                <p><strong>Onsite Score:</strong> @report.OnsiteScoreDetails.OnsiteScoreValue</p>
                <h3>Groundwater Score Details</h3>
                <p><strong>A:</strong> @report.GroundwaterScoreDetails.A</p>
                <p><strong>B1:</strong> @report.GroundwaterScoreDetails.B1</p>
                <p><strong>B2:</strong> @report.GroundwaterScoreDetails.B2</p>
                <p><strong>C:</strong> @report.GroundwaterScoreDetails.C</p>
                <p><strong>CASNO:</strong> @report.GroundwaterScoreDetails.CASNO</p>
                <p><strong>ChemName:</strong> @report.GroundwaterScoreDetails.ChemName</p>
                <p><strong>Other:</strong> @report.GroundwaterScoreDetails.Other</p>
                <p><strong>D2:</strong> @report.GroundwaterScoreDetails.D2</p>
                <p><strong>D3:</strong> @report.GroundwaterScoreDetails.D3</p>
                <p><strong>E1:</strong> @report.GroundwaterScoreDetails.E1</p>
                <p><strong>E2:</strong> @report.GroundwaterScoreDetails.E2</p>
                <p><strong>Description:</strong> @report.GroundwaterScoreDetails.Description</p>
                <p><strong>Groundwater Score:</strong> @report.GroundwaterScoreDetails.GWScore</p>
                <hr />
                <h3>Status</h3>
                <p><strong>Overall Status:</strong> @report.StatusDetails.OverallStatus.Name</p>
                <p><strong>Status Comments:</strong> @report.StatusDetails.Comments</p>
                <p><strong>Onsite Status:</strong> @report.StatusDetails.SoilStatus.Name</p>
                <p><strong>Groundwater Status:</strong> @report.StatusDetails.GroundwaterStatus.Name</p>
                <p><strong>GAPS Score:</strong> @report.StatusDetails.GAPSScore</p>
                <p><strong>GAPS Score Date:</strong> @report.StatusDetails.GAPSModelDate</p>
                <p><strong>GAPS Assessment:</strong> @Html.DisplayFor(Model => report.StatusDetails.GAPSAssessment.Name, "StringOrNone")</p>
                <hr />
                <h3>Substances</h3>
                @foreach (var substance in report.Substances)
                {
                    <p><strong>Name:</strong> @substance.Chemical.DisplayName</p>
                    <p><strong>Soil:</strong> @Html.DisplayFor(model => substance.Soil, "BoolYesNo")</p>
                    <p><strong>GW:</strong> @Html.DisplayFor(model => substance.Groundwater, "BoolYesNo")</p>
                    <p><strong>Use for Soil Scoring:</strong> @Html.DisplayFor(model => substance.UseForSoilScoring, "BoolYesNo")</p>
                    <p><strong>Use for GW Scoring:</strong> @Html.DisplayFor(model => substance.UseForGroundwaterScoring, "BoolYesNo")</p>
                    <hr />
                }
            </div>
        </div>
    }
}

