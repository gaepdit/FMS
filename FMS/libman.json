{
  "version": "3.0",
  "defaultProvider": "jsdelivr",
  "libraries": [
    {
      "library": "jquery@3.6.1",
      "destination": "wwwroot/lib/jquery/",
      "files": [
        "dist/jquery.min.js",
        "dist/jquery.min.map",
        "dist/jquery.js"
      ]
    },
    {
      "library": "bootstrap@5.3.1",
      "destination": "wwwroot/lib/bootstrap/",
      "files": [
        "dist/js/bootstrap.bundle.min.js",
        "dist/js/bootstrap.bundle.js",
        "dist/js/bootstrap.bundle.min.js.map",
        "dist/css/bootstrap.css",
        "dist/css/bootstrap.min.css",
        "dist/css/bootstrap.min.css.map"
      ]
    },
    {
      "library": "jquery-validation@1.19.5",
      "destination": "wwwroot/lib/jquery-validation",
      "files": [
        "dist/jquery.validate.min.js",
        "dist/jquery.validate.js"
      ]
    },
    {
      "library": "jquery-validation-unobtrusive@4.0.0",
      "destination": "wwwroot/lib/jquery-validation-unobtrusive",
      "files": [
        "dist/jquery.validate.unobtrusive.min.js",
        "dist/jquery.validate.unobtrusive.js"
      ]
    },
    {
      "library": "axios@1.13.2",
      "destination": "wwwroot/lib/axios/",
      "files": [
        "dist/axios.min.js",
        "dist/axios.js",
        "dist/axios.js.map",
        "dist/axios.min.js.map"
      ]
    },
    {
      "library": "npm-overlapping-marker-spiderfier@1.0.3",
      "destination": "wwwroot/lib/OverlappingMarkerSpiderfier/",
      "files": [
        "lib/**"
      ]
    },
    {
      "library": "sanitize.css@13.0.0",
      "destination": "wwwroot/lib/sanitize.css",
      "files": [
        "sanitize.min.css",
        "sanitize.css"
      ]
    },
    {
      "provider": "jsdelivr",
      "library": "sanitize.css@13.0.0",
      "destination": "wwwroot/lib/sanitize.css",
      "files": [
        "sanitize.min.css",
        "sanitize.css"
      ]
    }
  ]
}
